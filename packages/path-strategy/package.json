{
  "name": "@i18n-micro/path-strategy",
  "version": "1.3.2",
  "description": "Shared strategy-based path and route name builder for Nuxt I18n Micro frontend routing.",
  "keywords": [
    "i18n",
    "nuxt",
    "paths",
    "routing",
    "strategy"
  ],
  "homepage": "https://github.com/s00d/nuxt-i18n-micro",
  "bugs": {
    "url": "https://github.com/s00d/nuxt-i18n-micro/issues"
  },
  "license": "MIT",
  "author": {
    "name": "s00d",
    "email": "Virus191288@gmail.com",
    "url": "https://s00d.github.io/"
  },
  "repository": "s00d/nuxt-i18n-micro",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    },
    "./prefix": {
      "import": {
        "types": "./dist/strategies/prefix.d.ts",
        "default": "./dist/prefix-strategy.mjs"
      },
      "require": {
        "types": "./dist/strategies/prefix.d.cts",
        "default": "./dist/prefix-strategy.cjs"
      },
      "default": "./dist/prefix-strategy.mjs"
    },
    "./no-prefix": {
      "import": {
        "types": "./dist/strategies/no-prefix.d.ts",
        "default": "./dist/no-prefix-strategy.mjs"
      },
      "require": {
        "types": "./dist/strategies/no-prefix.d.cts",
        "default": "./dist/no-prefix-strategy.cjs"
      },
      "default": "./dist/no-prefix-strategy.mjs"
    },
    "./prefix-except-default": {
      "import": {
        "types": "./dist/strategies/prefix-except-default.d.ts",
        "default": "./dist/prefix-except-default-strategy.mjs"
      },
      "require": {
        "types": "./dist/strategies/prefix-except-default.d.cts",
        "default": "./dist/prefix-except-default-strategy.cjs"
      },
      "default": "./dist/prefix-except-default-strategy.mjs"
    },
    "./prefix-and-default": {
      "import": {
        "types": "./dist/strategies/prefix-and-default.d.ts",
        "default": "./dist/prefix-and-default-strategy.mjs"
      },
      "require": {
        "types": "./dist/strategies/prefix-and-default.d.cts",
        "default": "./dist/prefix-and-default-strategy.cjs"
      },
      "default": "./dist/prefix-and-default-strategy.mjs"
    },
    "./types": {
      "import": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.mjs"
      },
      "require": {
        "types": "./dist/types.d.cts",
        "default": "./dist/types.cjs"
      },
      "default": "./dist/types.mjs"
    },
    "./package.json": "./package.json",
    "./dist/*": "./dist/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "jest",
    "test:dist": "vitest run --config vitest.dist.config.ts",
    "check:package": "publint",
    "test:publish": "pnpm run test:dist && pnpm run check:package",
    "test:perf": "jest --config jest.perf.config.cjs",
    "bench:browser": "vite --config bench/vite.config.ts",
    "bench:browser:ci": "tsx bench/run-headless.ts",
    "prepublishOnly": "pnpm run build && pnpm run test:publish"
  },
  "dependencies": {
    "@i18n-micro/types": "workspace:*"
  },
  "devDependencies": {
    "publint": "^0.3.17",
    "tsx": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18"
  }
}
