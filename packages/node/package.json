{
  "name": "@i18n-micro/node",
  "version": "1.2.3",
  "description": "Node.js utilities for loading translations and locale data in Nuxt I18n Micro.",
  "keywords": [
    "i18n",
    "node",
    "nuxt",
    "translations"
  ],
  "homepage": "https://github.com/s00d/nuxt-i18n-micro/tree/main/packages/node#readme",
  "bugs": {
    "url": "https://github.com/s00d/nuxt-i18n-micro/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s00d/nuxt-i18n-micro.git",
    "directory": "packages/node"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "check:package": "publint",
    "dev": "cd playground && npm run dev",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run check:package"
  },
  "dependencies": {
    "@i18n-micro/core": "workspace:*",
    "@i18n-micro/types": "workspace:*",
    "@i18n-micro/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "jest": "catalog:",
    "publint": "^0.3.17",
    "ts-jest": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
