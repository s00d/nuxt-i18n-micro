{
  "name": "@i18n-micro/test-utils",
  "version": "1.2.1",
  "description": "Testing helpers for Nuxt I18n Micro (translations, locales, formatting mocks).",
  "keywords": [
    "i18n",
    "jest",
    "nuxt",
    "testing",
    "vitest"
  ],
  "homepage": "https://github.com/s00d/nuxt-i18n-micro/tree/main/packages/test-utils#readme",
  "bugs": {
    "url": "https://github.com/s00d/nuxt-i18n-micro/issues"
  },
  "license": "MIT",
  "author": {
    "name": "s00d",
    "email": "Virus191288@gmail.com",
    "url": "https://s00d.github.io/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s00d/nuxt-i18n-micro.git",
    "directory": "packages/test-utils"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    },
    "./publish-smoke": {
      "import": {
        "types": "./src/publish-smoke.ts",
        "default": "./src/publish-smoke.ts"
      },
      "default": "./src/publish-smoke.ts"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "check:package": "publint",
    "test": "jest",
    "prepublishOnly": "pnpm run build && pnpm run check:package"
  },
  "dependencies": {
    "@i18n-micro/core": "workspace:*"
  },
  "devDependencies": {
    "publint": "^0.3.17",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:"
  },
  "engines": {
    "node": ">=18"
  }
}
