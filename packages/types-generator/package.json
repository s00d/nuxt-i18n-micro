{
  "name": "@i18n-micro/types-generator",
  "version": "1.1.2",
  "description": "Type generator for i18n-micro translation keys",
  "keywords": [
    "i18n",
    "nuxt",
    "translation",
    "type-generator",
    "typescript"
  ],
  "homepage": "https://github.com/s00d/nuxt-i18n-micro/tree/main/packages/types-generator#readme",
  "bugs": {
    "url": "https://github.com/s00d/nuxt-i18n-micro/issues"
  },
  "license": "MIT",
  "author": {
    "name": "s00d",
    "email": "Virus191288@gmail.com",
    "url": "https://s00d.github.io/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s00d/nuxt-i18n-micro.git",
    "directory": "packages/types-generator"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    },
    "./nuxt": {
      "import": {
        "types": "./dist/nuxt.d.ts",
        "default": "./dist/nuxt.mjs"
      },
      "require": {
        "types": "./dist/nuxt.d.cts",
        "default": "./dist/nuxt.cjs"
      },
      "default": "./dist/nuxt.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "check:package": "publint",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run check:package"
  },
  "dependencies": {
    "chokidar": "catalog:",
    "globby": "catalog:",
    "unplugin": "catalog:"
  },
  "devDependencies": {
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "jest": "catalog:",
    "publint": "^0.3.17",
    "ts-jest": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:"
  },
  "peerDependencies": {
    "@nuxt/kit": "catalog:"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
