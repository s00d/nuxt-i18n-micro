{
  "name": "@i18n-micro/route-strategy",
  "version": "1.1.7",
  "description": "Locale-aware route generator for Nuxt i18n micro",
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "check:package": "publint",
    "test": "jest",
    "test:dist": "vitest run --config vitest.dist.config.ts",
    "prepublishOnly": "pnpm run build && pnpm run check:package"
  },
  "keywords": [
    "i18n",
    "nuxt",
    "routes",
    "locale",
    "route-generator",
    "internationalization"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s00d/nuxt-i18n-micro.git",
    "directory": "packages/route-strategy"
  },
  "homepage": "https://github.com/s00d/nuxt-i18n-micro/tree/main/packages/route-strategy#readme",
  "bugs": {
    "url": "https://github.com/s00d/nuxt-i18n-micro/issues"
  },
  "license": "MIT",
  "author": {
    "name": "s00d",
    "email": "Virus191288@gmail.com",
    "url": "https://s00d.github.io/"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "dependencies": {
    "@i18n-micro/core": "workspace:*",
    "@i18n-micro/types": "workspace:*",
    "@nuxt/schema": "catalog:"
  },
  "devDependencies": {
    "@types/jest": "catalog:",
    "jest": "catalog:",
    "ts-jest": "catalog:",
    "publint": "^0.3.17",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18"
  }
}
