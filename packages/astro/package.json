{
  "name": "@i18n-micro/astro",
  "version": "1.3.4",
  "description": "Astro integration for i18n-micro — translations, routing, and islands.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s00d/nuxt-i18n-micro.git",
    "directory": "packages/astro"
  },
  "homepage": "https://github.com/s00d/nuxt-i18n-micro/tree/main/packages/astro#readme",
  "bugs": {
    "url": "https://github.com/s00d/nuxt-i18n-micro/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    },
    "./env": {
      "types": "./dist/env.d.ts"
    },
    "./components/i18n-t.astro": "./src/components/i18n-t.astro",
    "./components/i18n-link.astro": "./src/components/i18n-link.astro",
    "./components/i18n-switcher.astro": "./src/components/i18n-switcher.astro",
    "./components/i18n-group.astro": "./src/components/i18n-group.astro",
    "./i18n-t": "./src/components/i18n-t.astro",
    "./i18n-link": "./src/components/i18n-link.astro",
    "./i18n-switcher": "./src/components/i18n-switcher.astro",
    "./i18n-group": "./src/components/i18n-group.astro",
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./client/vue": {
      "types": "./dist/client/vue.d.ts",
      "import": "./dist/client/vue.js"
    },
    "./client/react": {
      "types": "./dist/client/react.d.ts",
      "import": "./dist/client/react.js"
    },
    "./client/preact": {
      "types": "./dist/client/preact.d.ts",
      "import": "./dist/client/preact.js"
    },
    "./client/svelte": {
      "types": "./dist/client/svelte.d.ts",
      "import": "./dist/client/svelte.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "astro",
    "i18n",
    "internationalization",
    "translations"
  ],
  "dependencies": {
    "@i18n-micro/core": "workspace:*",
    "@i18n-micro/types": "workspace:*",
    "@i18n-micro/node": "workspace:*"
  },
  "peerDependencies": {
    "astro": "catalog:",
    "svelte": "catalog:",
    "vue": "catalog:",
    "react": "catalog:",
    "preact": "catalog:"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "preact": {
      "optional": true
    }
  },
  "devDependencies": {
    "astro": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "jest": "catalog:",
    "ts-jest": "catalog:",
    "@types/jest": "catalog:",
    "svelte": "catalog:",
    "vue": "catalog:",
    "react": "catalog:",
    "preact": "catalog:",
    "publint": "^0.3.17",
    "vitest": "catalog:"
  },
  "scripts": {
    "build": "vite build",
    "check:package": "publint",
    "dev": "cd playground && astro dev",
    "test": "jest",
    "test:dist": "vitest run --config vitest.dist.config.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run check:package"
  }
}
